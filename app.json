{
  "expo": {
    "name": "PerX AI Wallet",
    "slug": "perx-ai-wallet",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSUserNotificationUsageDescription": "PERX sends you perk approvals, points expiry warnings, and new perk alerts.",
        "NSHealthShareUsageDescription": "PerX reads your steps and sleep from Apple Health to track wellness challenges.",
        "NSHealthUpdateUsageDescription": "PerX does not write health data."
      }
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#6366F1",
          "defaultChannel": "default"
        }
      ]
    ],
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#050816"
      },
      "permissions": [
        "android.permission.health.READ_STEPS",
        "android.permission.health.READ_SLEEP"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "local-perx-ai-wallet"
      }
    }
  }
}
