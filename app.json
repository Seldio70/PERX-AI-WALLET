{
  "expo": {
    "name": "PerX AI Wallet",
    "slug": "perx-ai-wallet",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSUserNotificationUsageDescription": "PERX sends you perk approvals, points expiry warnings, and new perk alerts."
      }
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#6366F1",
          "defaultChannel": "default"
        }
      ]
    ],
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#050816"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "local-perx-ai-wallet"
      }
    }
  }
}
